+async function fetchFbsActShipmentDates(
+  secrets: Secrets,
+  period: SalesPeriod | null | undefined,
+  fbsPayloads: Array<{ endpoint: string; payload: any }>,
+): Promise<Map<string, string>> {
+  const requestedPostings = new Set<string>()
+  for (const envelope of fbsPayloads) {
+    for (const posting of extractPostingsFromPayload(envelope.payload)) {
+      const postingNumber = normalizeTextValue((posting as any)?.posting_number ?? (posting as any)?.postingNumber)
+      if (postingNumber) requestedPostings.add(postingNumber)
+    }
+  }
+  if (requestedPostings.size === 0) return new Map<string, string>()
+
+  const actsPayload = await ozonPostingFbsActList(secrets, buildFbsActListBody(period))
+  const acts = extractFbsActEntries(actsPayload)
+  if (acts.length === 0) return new Map<string, string>()
+
+  const actRequests = acts
+    .map((act) => ({ id: Number((act as any)?.id), createdAt: normalizeTextValue((act as any)?.created_at) }))
+    .filter((act) => Number.isFinite(act.id) && act.id > 0 && act.createdAt)
+
+  const postingToShipmentDate = new Map<string, string>()
+  for (const batch of chunk(actRequests, 4)) {
+    const settled = await Promise.allSettled(batch.map(async (act) => ({
+      act,
+      payload: await ozonPostingFbsActGetPostings(secrets, act.id),
+    })))
+    for (const result of settled) {
+      if (result.status !== 'fulfilled') continue
+      const createdAt = normalizeTextValue(result.value.act.createdAt)
+      if (!createdAt) continue
+      for (const postingNumber of extractFbsActPostingNumbers(result.value.payload)) {
+        if (!requestedPostings.has(postingNumber)) continue
+        const prev = postingToShipmentDate.get(postingNumber)
+        if (!prev || createdAt > prev) postingToShipmentDate.set(postingNumber, createdAt)
+      }
+    }
+    if (batch.length === 4) await new Promise((resolve) => setTimeout(resolve, 120))
+  }
+
+  return postingToShipmentDate
+}
+
+function applyPostingShipmentOverrides(rows: any[], overrides: Map<string, string>): any[] {
+  if (!Array.isArray(rows) || rows.length === 0 || overrides.size === 0) return rows
+  let changed = false
+  const nextRows = rows.map((row) => {
+    const postingNumber = normalizeTextValue((row as any)?.posting_number)
+    const override = postingNumber ? normalizeTextValue(overrides.get(postingNumber)) : ''
+    if (!override) return row
+    const current = normalizeTextValue((row as any)?.shipment_date)
+    if (current === override) return row
+    changed = true
+    return { ...row, shipment_date: override }
+  })
+  return changed ? nextRows : rows
+}
