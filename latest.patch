+function toIsoDayStart(value: string | null | undefined): string {
+  const day = normalizeSalesPeriodValue(value)
+  return day ? `${day}T00:00:00.000Z` : ''
+}
+
+function toIsoDayEnd(value: string | null | undefined): string {
+  const day = normalizeSalesPeriodValue(value)
+  return day ? `${day}T23:59:59.999Z` : ''
+}
+
+function buildFbsActListBody(period: SalesPeriod | null | undefined): any {
+  const normalized = normalizeSalesPeriod(period)
+  const filter: Record<string, unknown> = {}
+  const dateFrom = toIsoDayStart(normalized.from)
+  const dateTo = toIsoDayEnd(normalized.to)
+  if (dateFrom) filter.date_from = dateFrom
+  if (dateTo) filter.date_to = dateTo
+  return Object.keys(filter).length > 0
+    ? { limit: 1000, filter }
+    : { limit: 1000 }
+}
+
+function extractFbsActEntries(payload: any): any[] {
+  if (Array.isArray(payload?.result)) return payload.result
+  if (Array.isArray(payload?.result?.acts)) return payload.result.acts
+  if (Array.isArray(payload?.acts)) return payload.acts
+  if (Array.isArray(payload?.items)) return payload.items
+  return []
+}
+
+function looksLikePostingNumber(value: string): boolean {
+  return /^\d[\d-]{4,}$/.test(value)
+}
+
+function extractFbsActPostingNumbers(payload: any): string[] {
+  const buckets = [payload?.result, payload?.items, payload?.postings, payload]
+  const out: string[] = []
+  const seen = new Set<string>()
+
+  const pushOne = (value: any) => {
+    const raw = normalizeTextValue(value)
+    if (!raw || !looksLikePostingNumber(raw) || seen.has(raw)) return
+    seen.add(raw)
+    out.push(raw)
+  }
+
+  const walk = (value: any) => {
+    if (value == null) return
+    if (Array.isArray(value)) {
+      for (const item of value) walk(item)
+      return
+    }
+    if (typeof value !== 'object') {
+      pushOne(value)
+      return
+    }
+
+    pushOne((value as any).posting_number)
+    pushOne((value as any).postingNumber)
+    pushOne((value as any).number)
+    pushOne((value as any).value)
+
+    for (const nested of Object.values(value as Record<string, unknown>)) {
+      if (nested && typeof nested === 'object') walk(nested)
+    }
+  }
+
+  for (const bucket of buckets) walk(bucket)
+  return out
+}
+
+function escapeCsvCell(value: string): string {
+  if (!/[",\n\r]/.test(value)) return value
+  return `"${value.replace(/"/g, '""')}"`
+}
+
+function serializeSalesShipmentReportCsv(rows: SalesShipmentReportRow[]): string {
+  const lines: string[] = [SALES_SHIPMENT_REPORT_HEADERS.join(',')]
+  for (const row of rows) {
+    const cells = SALES_SHIPMENT_REPORT_HEADERS.map((header) => escapeCsvCell(normalizeTextValue(row[header] ?? '')))
+    lines.push(cells.join(','))
+  }
+  return `${lines.join('\n')}\n`
+}
+
+function parseCsvTable(text: string): string[][] {
+  const rows: string[][] = []
+  let row: string[] = []
+  let cell = ''
+  let inQuotes = false
+
+  for (let i = 0; i < text.length; i += 1) {
+    const ch = text[i]
+    if (inQuotes) {
+      if (ch === '"') {
+        if (text[i + 1] === '"') {
+          cell += '"'
+          i += 1
+        } else {
+          inQuotes = false
+        }
+      } else {
+        cell += ch
+      }
+      continue
+    }
+
+    if (ch === '"') {
+      inQuotes = true
+      continue
+    }
+    if (ch === ',') {
+      row.push(cell)
+      cell = ''
+      continue
+    }
+    if (ch === '\n') {
+      row.push(cell)
+      rows.push(row)
+      row = []
+      cell = ''
+      continue
+    }
+    if (ch === '\r') continue
+    cell += ch
+  }
+
+  if (cell || row.length > 0) {
+    row.push(cell)
+    rows.push(row)
+  }
+
+  return rows
+}
+
+function parseSalesShipmentReportCsv(text: string): SalesShipmentReportRow[] {
+  const table = parseCsvTable(text)
+  if (table.length === 0) return []
+  const header = table[0].map((value) => normalizeTextValue(value))
+  const rows: SalesShipmentReportRow[] = []
+  for (const cells of table.slice(1)) {
+    if (cells.length === 0 || cells.every((value) => !normalizeTextValue(value))) continue
+    const entry: Record<string, string> = {}
+    for (let i = 0; i < header.length; i += 1) {
+      const key = header[i]
+      if (!key) continue
+      entry[key] = normalizeTextValue(cells[i] ?? '')
+    }
+    const postingNumber = normalizeTextValue(entry.posting_number)
+    if (!postingNumber) continue
+    rows.push({
+      posting_number: postingNumber,
+      shipment_date: normalizeTextValue(entry.shipment_date),
+      delivery_model: normalizeTextValue(entry.delivery_model),
+      status: normalizeTextValue(entry.status),
+      status_details: normalizeTextValue(entry.status_details),
+      carrier_status_details: normalizeTextValue(entry.carrier_status_details),
+      in_process_at: normalizeTextValue(entry.in_process_at),
+      source_kind: normalizeTextValue(entry.source_kind),
+    })
+  }
+  return rows
+}
+
+function buildSalesShipmentReportRows(rows: any[], actShipmentDates?: Map<string, string>): SalesShipmentReportRow[] {
+  const byPosting = new Map<string, SalesShipmentReportRow>()
+  for (const row of Array.isArray(rows) ? rows : []) {
+    const postingNumber = normalizeTextValue((row as any)?.posting_number)
+    if (!postingNumber) continue
+    const shipmentDate = normalizeTextValue((row as any)?.shipment_date)
+    if (!shipmentDate) continue
+    const sourceKind = actShipmentDates?.get(postingNumber) === shipmentDate ? 'fbs-act-list' : 'sales-cache'
+    const current: SalesShipmentReportRow = {
+      posting_number: postingNumber,
+      shipment_date: shipmentDate,
+      delivery_model: normalizeTextValue((row as any)?.delivery_model),
+      status: normalizeTextValue((row as any)?.status),
+      status_details: normalizeTextValue((row as any)?.status_details),
+      carrier_status_details: normalizeTextValue((row as any)?.carrier_status_details),
+      in_process_at: normalizeTextValue((row as any)?.in_process_at),
+      source_kind: sourceKind,
+    }
+    const prev = byPosting.get(postingNumber)
+    if (!prev || current.shipment_date > prev.shipment_date) byPosting.set(postingNumber, current)
+  }
+  return Array.from(byPosting.values()).sort((left, right) => left.posting_number.localeCompare(right.posting_number))
+}
+
+function persistSalesShipmentReportCsv(args: {
+  storeClientId?: string | null
+  scopeKey?: string | null
+  rows: any[]
+  actShipmentDates?: Map<string, string>
+}) {
+  const path = getSalesShipmentReportPath(args.storeClientId ?? null, args.scopeKey ?? '')
+  mkdirSync(dirname(path), { recursive: true })
+  const reportRows = buildSalesShipmentReportRows(args.rows, args.actShipmentDates)
+  const csvText = serializeSalesShipmentReportCsv(reportRows)
+  writeFileSync(path, csvText, 'utf8')
+  return { path, rowsCount: reportRows.length }
+}
+
+function readSalesShipmentReportMap(storeClientId: string | null | undefined, scopeKey?: string | null): Map<string, string> {
+  const path = getSalesShipmentReportPath(storeClientId ?? null, scopeKey ?? '')
+  try {
+    const raw = readFileSync(path, 'utf8')
+    const rows = parseSalesShipmentReportCsv(raw)
+    const out = new Map<string, string>()
+    for (const row of rows) {
+      if (!row.posting_number || !row.shipment_date) continue
+      const prev = out.get(row.posting_number)
+      if (!prev || row.shipment_date > prev) out.set(row.posting_number, row.shipment_date)
+    }
+    return out
+  } catch {
+    return new Map<string, string>()
+  }
+}
+
+function applySalesShipmentReportOverrides(rows: any[], shipmentReportMap: Map<string, string>): any[] {
+  if (!Array.isArray(rows) || rows.length === 0 || shipmentReportMap.size === 0) return rows
+  let changed = false
+  const nextRows = rows.map((row) => {
+    const postingNumber = normalizeTextValue((row as any)?.posting_number)
+    const shipmentDate = postingNumber ? normalizeTextValue(shipmentReportMap.get(postingNumber)) : ''
+    if (!shipmentDate) return row
+    const current = normalizeTextValue((row as any)?.shipment_date)
+    if (current === shipmentDate) return row
+    changed = true
+    return { ...row, shipment_date: shipmentDate }
+  })
+  return changed ? nextRows : rows
+}
