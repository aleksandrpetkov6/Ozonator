+
+function sanitizeFilePart(value: string | null | undefined): string {
+  const raw = String(value ?? '').trim()
+  const cleaned = raw.replace(/[^a-zA-Z0-9._-]+/g, '_').replace(/^_+|_+$/g, '')
+  return cleaned || 'default'
+}
+
+export function getPersistentReportsDir() {
+  return join(getPersistentRootDir(), 'reports')
+}
+
+export function getSalesShipmentReportPath(storeClientId: string | null | undefined, scopeKey?: string | null) {
+  const storePart = sanitizeFilePart(storeClientId)
+  const scopePart = sanitizeFilePart(scopeKey)
+  return join(getPersistentReportsDir(), `sales-shipment-report-${storePart}-${scopePart}.csv`)
+}
