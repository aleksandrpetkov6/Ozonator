+const FBO_SHIPMENT_STATE_KEYS = new Set([
+  'posting_transferring_to_delivery',
+  'posting_transfered_to_courier_service',
+  'posting_transferred_to_courier_service',
+])
+
+const FBO_DELIVERED_STATE_KEYS = new Set([
+  'delivered',
+  'delivered_to_customer',
+  'customer_received',
+  'posting_delivered',
+  'posting_delivered_to_customer',
+  'posting_conditionally_delivered',
+  'posting_returned',
+  'posting_returned_to_seller',
+  'returned_to_seller',
+])
+
+function normalizeLookupKey(value: any): string {
+  let raw = text(value)
+  if (!raw) return ''
+  const prefixed = raw.match(/^(status|state|new_state)\s*[:=]\s*(.+)$/i)
+  if (prefixed?.[2]) raw = prefixed[2].trim()
+  return raw
+    .toLowerCase()
+    .replace(/[|]+/g, ' ')
+    .replace(/[./\\]+/g, ' ')
+    .replace(/[:=]+/g, ' ')
+    .replace(/[_\-\s]+/g, '_')
+    .replace(/^_+|_+$/g, '')
+}
+
+function collectStateEvents(...sources: any[]): Array<{ state: string; changedStateDate: string }> {
+  const out: Array<{ state: string; changedStateDate: string }> = []
+  const seen = new Set<string>()
+  const visited = new Set<any>()
+  const walk = (node: any) => {
+    if (!node || typeof node !== 'object') return
+    if (visited.has(node)) return
+    visited.add(node)
+    if (Array.isArray(node)) {
+      for (const item of node) walk(item)
+      return
+    }
+    const state = normalizeLookupKey(pick(node, ['new_state', 'result.new_state', 'state', 'result.state', 'status', 'result.status']))
+    const changedStateDate = dateText(pick(node, ['changed_state_date', 'result.changed_state_date']))
+    if (state && changedStateDate) {
+      const key = `${state}|${changedStateDate}`
+      if (!seen.has(key)) {
+        seen.add(key)
+        out.push({ state, changedStateDate })
+      }
+    }
+    for (const value of Object.values(node)) walk(value)
+  }
+  for (const source of sources) walk(source)
+  return out
+}
+
+function findLatestStateDate(sources: any[], states: Set<string>): string {
+  let best = ''
+  for (const event of collectStateEvents(...sources)) {
+    if (!states.has(event.state)) continue
+    if (!best || event.changedStateDate > best) best = event.changedStateDate
+  }
+  return best
+}
+
+function hasDeliveredState(...sources: any[]): boolean {
+  const direct = normalizedStateOf(...sources)
+  if (direct && FBO_DELIVERED_STATE_KEYS.has(direct)) return true
+  for (const event of collectStateEvents(...sources)) {
+    if (FBO_DELIVERED_STATE_KEYS.has(event.state)) return true
+  }
+  return false
+}
+
+function sameMoment(left: any, right: any): boolean {
+  const leftText = text(left)
+  const rightText = text(right)
+  if (!leftText || !rightText) return false
+  const leftDate = new Date(leftText)
+  const rightDate = new Date(rightText)
+  if (Number.isNaN(leftDate.getTime()) || Number.isNaN(rightDate.getTime())) return leftText === rightText
+  return leftDate.getTime() === rightDate.getTime()
+}
+
+function isDeliveredStatusLabel(value: any): boolean {
+  const raw = text(value).toLowerCase()
+  if (!raw) return false
+  return raw.includes('доставлен') || raw.includes('получен покупателем') || raw.includes('условно доставлен')
+}
