 // Add Vite-specific ImportMeta type to satisfy TypeScript.
 // This mirrors the shape of import.meta.env used in Vite projects.
 declare global {
   interface ImportMeta {
     /**
      * Vite exposes environment variables via `import.meta.env`.
      * The exact shape depends on the variables defined in `.env` files.
      * We declare it as an index signature to allow any key.
      */
     env: {
       [key: string]: any;
     };
   }
 }
 
 // Ensure the file is treated as a module so that the global augmentation is applied.
 export {};

