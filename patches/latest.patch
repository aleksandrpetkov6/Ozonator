+function isSalesDateStrictlyAfter(candidate: string, reference: string): boolean {
+  if (!candidate) return false
+  if (!reference) return true
+  const candidateTime = Date.parse(candidate)
+  const referenceTime = Date.parse(reference)
+  if (Number.isFinite(candidateTime) && Number.isFinite(referenceTime)) return candidateTime > referenceTime
+  return candidate > reference
+}
