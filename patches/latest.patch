+function backfillSalesShipmentDatesFromRelatedRows(rows: SalesRow[]): SalesRow[] {
+  if (rows.length === 0) return rows
+
+  const adjacency = new Map<string, Set<string>>()
+  const connect = (left: string, right: string) => {
+    if (!left || !right || left === right) return
+    let leftSet = adjacency.get(left)
+    if (!leftSet) {
+      leftSet = new Set<string>()
+      adjacency.set(left, leftSet)
+    }
+    let rightSet = adjacency.get(right)
+    if (!rightSet) {
+      rightSet = new Set<string>()
+      adjacency.set(right, rightSet)
+    }
+    leftSet.add(right)
+    rightSet.add(left)
+  }
+
+  const shipmentDateByPosting = new Map<string, string>()
+
+  for (const row of rows) {
+    const postingNumber = normalizeTextValue(row.posting_number)
+    if (!postingNumber) continue
+    if (!adjacency.has(postingNumber)) adjacency.set(postingNumber, new Set<string>())
+
+    const currentShipmentDate = normalizeDateValue(row.shipment_date)
+    if (currentShipmentDate) {
+      const previousShipmentDate = shipmentDateByPosting.get(postingNumber)
+      if (!previousShipmentDate || currentShipmentDate < previousShipmentDate) shipmentDateByPosting.set(postingNumber, currentShipmentDate)
+    }
+
+    for (const relatedPostingNumber of splitRelatedPostingNumbers(row.related_postings)) {
+      connect(postingNumber, relatedPostingNumber)
+    }
+  }
+
+  const componentShipmentDate = new Map<string, string>()
+  const visited = new Set<string>()
+
+  for (const postingNumber of adjacency.keys()) {
+    if (visited.has(postingNumber)) continue
+    const queue = [postingNumber]
+    const component: string[] = []
+    let bestShipmentDate = ''
+
+    while (queue.length > 0) {
+      const current = queue.shift() ?? ''
+      if (!current || visited.has(current)) continue
+      visited.add(current)
+      component.push(current)
+
+      const currentShipmentDate = shipmentDateByPosting.get(current) ?? ''
+      if (currentShipmentDate && (!bestShipmentDate || currentShipmentDate < bestShipmentDate)) bestShipmentDate = currentShipmentDate
+
+      for (const next of adjacency.get(current) ?? []) {
+        if (!visited.has(next)) queue.push(next)
+      }
+    }
+
+    if (!bestShipmentDate || component.length < 2) continue
+    for (const current of component) componentShipmentDate.set(current, bestShipmentDate)
+  }
+
+  return rows.map((row) => {
+    if (normalizeDateValue(row.shipment_date)) return row
+    const postingNumber = normalizeTextValue(row.posting_number)
+    if (!postingNumber) return row
+    const nextShipmentDate = componentShipmentDate.get(postingNumber) ?? ''
+    if (!nextShipmentDate) return row
+    return { ...row, shipment_date: nextShipmentDate }
+  })
+}
